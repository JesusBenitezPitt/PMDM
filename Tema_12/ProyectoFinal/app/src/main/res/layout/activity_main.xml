<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground"
    android:gravity="center"
    android:fitsSystemWindows="true">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MAZE"
        android:textColor="@color/colorPlayer"
        android:textSize="72sp"
        android:textStyle="bold"
        android:letterSpacing="0.3" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RUNNER"
        android:textColor="@color/colorText"
        android:textSize="32sp"
        android:textStyle="bold"
        android:letterSpacing="0.5"
        android:layout_marginBottom="16dp" />

    <View
        android:layout_width="120dp"
        android:layout_height="3dp"
        android:background="@color/colorAccent"
        android:layout_marginBottom="48dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MEJOR: "
            android:textColor="#AAAAAA"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvHighScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@color/colorCoin"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <Button
        android:id="@+id/btnPlay"
        style="@style/ButtonStyle"
        android:layout_width="200dp"
        android:layout_height="56dp"
        android:text="@string/btn_play"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="16dp"
        android:textSize="20sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="48dp"
        android:gravity="center">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="4dp">

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@color/colorEnemyChaser"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perseguidor"
                android:textColor="#AAAAAA"
                android:textSize="14sp" />

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@color/colorEnemyRandom"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aleatorio"
                android:textColor="#AAAAAA"
                android:textSize="14sp" />

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@color/colorEnemyPatrol"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Patrullero"
                android:textColor="#AAAAAA"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐ Recoge monedas · Evita enemigos · Llega a la salida"
            android:textColor="#666666"
            android:textSize="12sp"
            android:layout_marginTop="8dp" />
    </LinearLayout>

</LinearLayout>
